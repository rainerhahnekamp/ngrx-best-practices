{
  "implicitDependencies": {
    "angular.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "tsconfig.base.json": "*",
    "tslint.json": "*",
    ".eslintrc.json": "*",
    "nx.json": "*"
  },
  "affected": {
    "defaultBase": "master"
  },
  "npmScope": "eternal",
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"]
      }
    }
  },
  "projects": {
    "eternal": {
      "tags": ["type:app"]
    },
    "eternal-e2e": {
      "tags": [],
      "implicitDependencies": ["eternal"]
    },
    "customer-feature": {
      "tags": ["scope:customer", "type:feature"]
    },
    "customer-ui": {
      "tags": ["scope:customer", "type:ui"]
    },
    "customer-data": {
      "tags": ["scope:customer", "type:data"]
    },
    "customer-model": {
      "tags": ["scope:customer", "type:model"]
    }
  }
}
